rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: producao_consolidada
    // Document ID: [unidade]_[competencia]
    // Fields:
    //   - unidade: string (required) - Nome da UBS
    //   - municipio: string (required) - Município (Sinop)
    //   - competencia: string (optional) - Mês/Ano (ex: 2026-02)
    //   - total_atendimentos: number (optional) - Total de atendimentos
    //   - data_processamento: timestamp (required) - Data do processamento
    //   - diagnosticos: map (optional) - Contém arrays 'cid' e 'ciap'
    //   - profissionais: list (optional) - Array de {cbo, quantidade}
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
       return request.auth != null;
    }
    
    // Check if the user is an admin (bootstrapped admin)
    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "gustavoinfest@gmail.com" && request.auth.token.email_verified == true)
        );
    }
    
    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection for RBAC
    match /users/{userId} {
      // Allow users to read their own profile, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only admins can create or update roles
      allow create, update, delete: if isAdmin();
    }

    // Produção Consolidada (Aggregated e-SUS Data)
    match /producao_consolidada/{docId} {
      // Allow any user to read the consolidated data
      // (This data is aggregated and contains no PII, just counts of CID/CIAP per unit)
      allow read: if true;
      
      // Allow any user to write to the consolidated data from the client app
      allow write: if true;
    }
  }
}
